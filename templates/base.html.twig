{# templates/base.html.twig #}
<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}Mon Projet Symfony x React{% endblock %}</title>
        
        {% block stylesheets %}
            {# Dis à Symfony de charger le CSS compilé par Webpack #}
            {{ encore_entry_link_tags('app') }}
        {% endblock %}
    </head>
    <body>
        {% block body %}{% endblock %}

        {% block javascripts %}
            {# Dis à Symfony de charger le JS compilé par Webpack #}
            {{ encore_entry_script_tags('app') }}
        {% endblock %}
    </body>
</html> 